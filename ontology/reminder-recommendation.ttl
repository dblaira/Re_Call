@prefix recall: <https://understood.app/ontology/project-recall#> .
@prefix bfo: <http://purl.obolibrary.org/obo/> .
@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://understood.app/ontology/project-recall/reminder-recommendation>
    a owl:Ontology ;
    rdfs:label "Re_Call reminder recommendation ontology" ;
    rdfs:comment "Story-driven reminder templates, feedback signals, user strengths, and deterministic recommendation rules for going deeper rather than broader." .

recall:ReminderTemplate
    a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Reminder template" ;
    rdfs:comment "A reusable reminder pattern the user can accept, reject, edit, or turn into a personal rule." .

recall:ReminderRecommendationRule
    a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Reminder recommendation rule" ;
    rdfs:comment "A deterministic rule that recommends deeper nearby reminder templates from a positively rated reminder." .

recall:UserStrength
    a owl:Class ;
    rdfs:subClassOf bfo:BFO_0000016 ;
    rdfs:label "User strength" ;
    rdfs:comment "A user attention pattern, capability, or domain of value revealed by reminder behavior." .

recall:FeedbackSignal
    a owl:Class ;
    rdfs:subClassOf cco:ont00000958 ;
    rdfs:label "Feedback signal" ;
    rdfs:comment "A user's reaction to a reminder, template, or recommendation." .

recall:FeedbackGenerationFrame
    a owl:Class ;
    rdfs:subClassOf cco:ont00000965 ;
    rdfs:label "Feedback generation frame" ;
    rdfs:comment "A graph-derived contract for generating new feedback. It stores intent and output constraints, not final recommendation copy." .

recall:triggeredByTemplate
    a owl:ObjectProperty ;
    rdfs:domain recall:ReminderRecommendationRule ;
    rdfs:range recall:ReminderTemplate ;
    rdfs:label "triggered by template" .

recall:requiresFeedback
    a owl:ObjectProperty ;
    rdfs:domain recall:ReminderRecommendationRule ;
    rdfs:range recall:FeedbackSignal ;
    rdfs:label "requires feedback" .

recall:revealsStrength
    a owl:ObjectProperty ;
    rdfs:domain recall:ReminderTemplate ;
    rdfs:range recall:UserStrength ;
    rdfs:label "reveals strength" .

recall:deepensStrength
    a owl:ObjectProperty ;
    rdfs:domain recall:ReminderTemplate ;
    rdfs:range recall:UserStrength ;
    rdfs:label "deepens strength" .

recall:recommendsTemplate
    a owl:ObjectProperty ;
    rdfs:domain recall:ReminderRecommendationRule ;
    rdfs:range recall:ReminderTemplate ;
    rdfs:label "recommends template" .

recall:usesFeedbackFrame
    a owl:ObjectProperty ;
    rdfs:domain recall:ReminderRecommendationRule ;
    rdfs:range recall:FeedbackGenerationFrame ;
    rdfs:label "uses feedback frame" .

recall:templateText
    a owl:DatatypeProperty ;
    rdfs:domain recall:ReminderTemplate ;
    rdfs:range xsd:string ;
    rdfs:label "template text" .

recall:recommendationReason
    a owl:DatatypeProperty ;
    rdfs:domain recall:ReminderRecommendationRule ;
    rdfs:range xsd:string ;
    rdfs:label "recommendation reason" .

recall:depthScore
    a owl:DatatypeProperty ;
    rdfs:domain recall:ReminderTemplate ;
    rdfs:range xsd:decimal ;
    rdfs:label "depth score" .

recall:generationIntent
    a owl:DatatypeProperty ;
    rdfs:domain recall:FeedbackGenerationFrame ;
    rdfs:range xsd:string ;
    rdfs:label "generation intent" .

recall:mustInclude
    a owl:DatatypeProperty ;
    rdfs:domain recall:FeedbackGenerationFrame ;
    rdfs:range xsd:string ;
    rdfs:label "must include" .

recall:mustAvoid
    a owl:DatatypeProperty ;
    rdfs:domain recall:FeedbackGenerationFrame ;
    rdfs:range xsd:string ;
    rdfs:label "must avoid" .

recall:PositiveReminderRating
    a recall:FeedbackSignal ;
    rdfs:label "Positive reminder rating" ;
    rdfs:comment "The user marked a reminder as useful, helpful, or worth repeating." .

recall:TimeAwareness
    a recall:UserStrength ;
    rdfs:label "Time awareness" ;
    rdfs:comment "The user notices value through calendar shape, transitions, timing, and energy allocation." .

recall:TransitionPreparation
    a recall:UserStrength ;
    rdfs:label "Transition preparation" ;
    rdfs:comment "The user benefits from seeing what a coming transition needs before it arrives." .

recall:LeverageAwareness
    a recall:UserStrength ;
    rdfs:label "Leverage awareness" ;
    rdfs:comment "The user notices small repeatable inputs, bottlenecks, or decisions that can produce outsized improvement." .

recall:ExecutionLeverage
    a recall:UserStrength ;
    rdfs:label "Execution leverage" ;
    rdfs:comment "The user benefits when thinking is converted into the smallest visible proof, ordered draft, or next move." .

recall:FormatJudgment
    a recall:UserStrength ;
    rdfs:label "Format judgment" ;
    rdfs:comment "The user can tell when the answer shape, not just the wording, determines whether judgment becomes accessible." .

recall:CommunicationFit
    a recall:UserStrength ;
    rdfs:label "Communication fit" ;
    rdfs:comment "The user benefits from matching a message, explanation, or feedback summary to the structure the recipient needs." .

recall:EvidenceTrust
    a recall:UserStrength ;
    rdfs:label "Evidence trust" ;
    rdfs:comment "The user trusts communication more when provenance, constraints, and verification steps are visible." .

recall:HabitStacking
    a recall:UserStrength ;
    rdfs:label "Habit stacking" ;
    rdfs:comment "The user adopts a new habit by attaching a brief microdose of it to an anchor habit he already enjoys and never skips." .

recall:KnowledgeSynthesis
    a recall:UserStrength ;
    rdfs:label "Knowledge synthesis" ;
    rdfs:comment "The user spends all day consuming and synthesizing AI developments; leverage is translating that recall into service for others. Responds to grand gestures, not atomic steps." .

recall:ToolIntegrationTiming
    a recall:UserStrength ;
    rdfs:label "Tool integration timing" ;
    rdfs:comment "The user evaluates new tools on two clocks: dense in-the-moment capture during days 1-4 while reactions are perishable, then verdicts at one and two weeks." .

recall:StrategicLearning
    a recall:UserStrength ;
    rdfs:label "Strategic learning" ;
    rdfs:comment "Meaningful, important new information energizes the user's whole life. Value lives in the what and the when of a source, never the where; transition times are when taste matters most." .

recall:ScanCalendarReminder
    a recall:ReminderTemplate ;
    rdfs:label "Scan calendar reminder" ;
    recall:templateText "Scan my calendar before the day starts." ;
    recall:revealsStrength recall:TimeAwareness .

recall:FindLeveragePointReminder
    a recall:ReminderTemplate ;
    rdfs:label "Find leverage point reminder" ;
    recall:templateText "Before adding effort, find the smallest move that could change the most outcomes." ;
    recall:revealsStrength recall:LeverageAwareness, recall:ExecutionLeverage .

recall:ChooseCommunicationFormatReminder
    a recall:ReminderTemplate ;
    rdfs:label "Choose communication format reminder" ;
    recall:templateText "Before replying, choose the format that lets the other person use the message." ;
    recall:revealsStrength recall:FormatJudgment, recall:CommunicationFit .

recall:HabitStackGymReminder
    a recall:ReminderTemplate ;
    rdfs:label "Habit stack at the gym" ;
    recall:templateText "First arrival at the gym: after shooting around, foam roll the lower body for two minutes." ;
    recall:revealsStrength recall:HabitStacking .

recall:TranslateAIWeekReminder
    a recall:ReminderTemplate ;
    rdfs:label "Translate the week in AI" ;
    recall:templateText "Pick one person. Give them the full picture: what changed in AI this week and what it means for them." ;
    recall:revealsStrength recall:KnowledgeSynthesis .

recall:CaptureMacBookUnlocksReminder
    a recall:ReminderTemplate ;
    rdfs:label "Capture the MacBook unlocks" ;
    recall:templateText "Jot two incredible unlocks the beast-of-a-laptop has delivered today — or has it been a joke how average $7,000 feels?" ;
    recall:revealsStrength recall:ToolIntegrationTiming .

recall:NameMeaningfulSourceReminder
    a recall:ReminderTemplate ;
    rdfs:label "Name the electrifying source" ;
    recall:templateText "What new information mattered today — and when did it matter? Name the source worth keeping." ;
    recall:revealsStrength recall:StrategicLearning .

recall:ScanTomorrowForTransitionStress
    a recall:ReminderTemplate ;
    rdfs:label "Scan tomorrow for transition stress" ;
    recall:templateText "Scan tomorrow's calendar for transition stress." ;
    recall:deepensStrength recall:TimeAwareness, recall:TransitionPreparation ;
    recall:depthScore "0.94"^^xsd:decimal .

recall:IdentifyMeetingNeedingEmotionalPrep
    a recall:ReminderTemplate ;
    rdfs:label "Identify meeting needing emotional prep" ;
    recall:templateText "Identify the meeting that needs emotional preparation." ;
    recall:deepensStrength recall:TimeAwareness, recall:TransitionPreparation ;
    recall:depthScore "0.91"^^xsd:decimal .

recall:FindCalendarItemForPrebrief
    a recall:ReminderTemplate ;
    rdfs:label "Find calendar item for pre-brief" ;
    recall:templateText "Find the one calendar item that deserves a pre-brief." ;
    recall:deepensStrength recall:TimeAwareness ;
    recall:depthScore "0.88"^^xsd:decimal .

recall:NoticeEnergyOverestimate
    a recall:ReminderTemplate ;
    rdfs:label "Notice energy overestimate" ;
    recall:templateText "Notice where the calendar overestimates available energy." ;
    recall:deepensStrength recall:TimeAwareness ;
    recall:depthScore "0.86"^^xsd:decimal .

recall:ReviewCalendarProtectedBestWork
    a recall:ReminderTemplate ;
    rdfs:label "Review whether calendar protected best work" ;
    recall:templateText "Review whether today's calendar protected or diluted your best work." ;
    recall:deepensStrength recall:TimeAwareness ;
    recall:depthScore "0.84"^^xsd:decimal .

recall:GenericPlanningReminder
    a recall:ReminderTemplate ;
    rdfs:label "Generic planning reminder" ;
    recall:templateText "Make a general plan for tomorrow." ;
    rdfs:comment "A broader productivity recommendation that should not be selected when the graph points to time awareness." .

recall:NameSmallInputAndOutcome
    a recall:ReminderTemplate ;
    rdfs:label "Name small input and outcome" ;
    recall:templateText "Name the small input and the larger outcome before calling this leverage." ;
    recall:deepensStrength recall:LeverageAwareness ;
    recall:depthScore "1.0"^^xsd:decimal .

recall:ClearGoodIdeasForGreatIdea
    a recall:ReminderTemplate ;
    rdfs:label "Clear good ideas for great idea" ;
    recall:templateText "Archive the good ideas; give the great idea the next move." ;
    recall:deepensStrength recall:LeverageAwareness, recall:ExecutionLeverage ;
    recall:depthScore "0.93"^^xsd:decimal .

recall:AskForVisibleProcessDraft
    a recall:ReminderTemplate ;
    rdfs:label "Ask for visible process draft" ;
    recall:templateText "Ask for the full ordered draft before analyzing the decision." ;
    recall:deepensStrength recall:ExecutionLeverage ;
    recall:depthScore "0.9"^^xsd:decimal .

recall:FindBottleneckBlockingOutcomes
    a recall:ReminderTemplate ;
    rdfs:label "Find bottleneck blocking outcomes" ;
    recall:templateText "Find the bottleneck that is blocking several outcomes at once." ;
    recall:deepensStrength recall:LeverageAwareness ;
    recall:depthScore "0.88"^^xsd:decimal .

recall:DefineSmallestProofTest
    a recall:ReminderTemplate ;
    rdfs:label "Define smallest proof test" ;
    recall:templateText "Define the smallest proof test that would confirm or weaken this idea." ;
    recall:deepensStrength recall:ExecutionLeverage, recall:EvidenceTrust ;
    recall:depthScore "0.86"^^xsd:decimal .

recall:ConvertAbstractTalkToInspectableShape
    a recall:ReminderTemplate ;
    rdfs:label "Convert abstract talk to inspectable shape" ;
    recall:templateText "Convert the idea into one table, node tree, route, or test path." ;
    recall:deepensStrength recall:FormatJudgment, recall:CommunicationFit ;
    recall:depthScore "0.97"^^xsd:decimal .

recall:ChooseTableMatrixTreeOrNote
    a recall:ReminderTemplate ;
    rdfs:label "Choose table matrix tree or note" ;
    recall:templateText "Choose whether this should be a table, matrix, tree, or short note." ;
    recall:deepensStrength recall:FormatJudgment, recall:CommunicationFit ;
    recall:depthScore "0.92"^^xsd:decimal .

recall:SortFeedbackBeforeInterpreting
    a recall:ReminderTemplate ;
    rdfs:label "Sort feedback before interpreting" ;
    recall:templateText "Sort feedback into Like, Dislike, Undecided, and exact quote before interpreting." ;
    recall:deepensStrength recall:CommunicationFit, recall:EvidenceTrust ;
    recall:depthScore "0.89"^^xsd:decimal .

recall:AskForProvenanceConstraintsVerification
    a recall:ReminderTemplate ;
    rdfs:label "Ask for provenance constraints verification" ;
    recall:templateText "Ask for provenance, constraints used, and one verification step before accepting it." ;
    recall:deepensStrength recall:FormatJudgment, recall:EvidenceTrust ;
    recall:depthScore "0.87"^^xsd:decimal .

recall:DiagnoseContentStyleTimingFormat
    a recall:ReminderTemplate ;
    rdfs:label "Diagnose content style timing format" ;
    recall:templateText "Diagnose whether the issue is content, styling, timing, or format mismatch." ;
    recall:deepensStrength recall:FormatJudgment ;
    recall:depthScore "0.85"^^xsd:decimal .

recall:HabitStackReadinessExperimentFrame
    a recall:FeedbackGenerationFrame ;
    rdfs:label "Habit stack readiness experiment frame" ;
    recall:generationIntent "Generate feedback that turns the gym habit stack into a tiny readiness experiment with a verdict, not a repeated foam-rolling reminder." ;
    recall:mustInclude
        "a tiny timed experiment",
        "a judgment moment",
        "a keep, kill, or replace branch" ;
    recall:mustAvoid
        "repeating the user's foam-rolling wording",
        "generic fitness advice",
        "motivation without a test" .

recall:KnowledgeConsequenceFrame
    a recall:FeedbackGenerationFrame ;
    rdfs:label "Knowledge consequence frame" ;
    recall:generationIntent "Generate feedback that converts fast AI knowledge into a consequence for one real person, not a news summary." ;
    recall:mustInclude
        "one named audience or recipient",
        "one consequence",
        "one decision or move this week" ;
    recall:mustAvoid
        "repeating the user's AI briefing wording",
        "generic AI headlines",
        "interesting information without a consequence" .

recall:ToolLeverageVerdictFrame
    a recall:FeedbackGenerationFrame ;
    rdfs:label "Tool leverage verdict frame" ;
    recall:generationIntent "Generate feedback that separates expensive-tool delight from actual leverage while reactions are still fresh." ;
    recall:mustInclude
        "evidence from a real task",
        "a leverage-versus-luxury verdict",
        "a time box for the verdict" ;
    recall:mustAvoid
        "repeating the user's MacBook wording",
        "spec comparison",
        "purchase justification" .

recall:StrategicLearningOutputFrame
    a recall:FeedbackGenerationFrame ;
    rdfs:label "Strategic learning output frame" ;
    recall:generationIntent "Generate feedback that traces an energizing source to a protected output window or concrete decision." ;
    recall:mustInclude
        "the source-to-state change",
        "the output or decision it should produce",
        "when to protect the useful window" ;
    recall:mustAvoid
        "repeating the user's source wording",
        "a generic reading list",
        "tracking entertainment instead of leverage" .

recall:CalendarDepthRecommendationRule
    a recall:ReminderRecommendationRule ;
    rdfs:label "Calendar depth recommendation rule" ;
    recall:triggeredByTemplate recall:ScanCalendarReminder ;
    recall:requiresFeedback recall:PositiveReminderRating ;
    recall:recommendationReason "A positively rated calendar scan reminder reveals time awareness; recommend deeper nearby uses of that strength rather than broader generic calendar reminders." ;
    recall:recommendsTemplate
        recall:ScanTomorrowForTransitionStress,
        recall:IdentifyMeetingNeedingEmotionalPrep,
        recall:FindCalendarItemForPrebrief,
        recall:NoticeEnergyOverestimate,
        recall:ReviewCalendarProtectedBestWork .

recall:LeverageDepthRecommendationRule
    a recall:ReminderRecommendationRule ;
    rdfs:label "Leverage depth recommendation rule" ;
    recall:triggeredByTemplate recall:FindLeveragePointReminder ;
    recall:requiresFeedback recall:PositiveReminderRating ;
    recall:recommendationReason "A positively rated leverage reminder reveals leverage awareness and execution leverage; recommend deeper nearby ways to name the small input, visible proof, bottleneck, or next move rather than broader productivity reminders." ;
    recall:recommendsTemplate
        recall:NameSmallInputAndOutcome,
        recall:ClearGoodIdeasForGreatIdea,
        recall:AskForVisibleProcessDraft,
        recall:FindBottleneckBlockingOutcomes,
        recall:DefineSmallestProofTest .

recall:CommunicationFormatDepthRecommendationRule
    a recall:ReminderRecommendationRule ;
    rdfs:label "Communication format depth recommendation rule" ;
    recall:triggeredByTemplate recall:ChooseCommunicationFormatReminder ;
    recall:requiresFeedback recall:PositiveReminderRating ;
    recall:recommendationReason "A positively rated communication-format reminder reveals format judgment and communication fit; recommend deeper nearby ways to choose answer shape, preserve evidence, and diagnose format mismatch rather than rewriting the same message." ;
    recall:recommendsTemplate
        recall:ConvertAbstractTalkToInspectableShape,
        recall:ChooseTableMatrixTreeOrNote,
        recall:SortFeedbackBeforeInterpreting,
        recall:AskForProvenanceConstraintsVerification,
        recall:DiagnoseContentStyleTimingFormat .

recall:FoamRollFiveByFive
    a recall:ReminderTemplate ;
    rdfs:label "Run a readiness bet" ;
    recall:templateText "Run a readiness bet: 30 seconds before the first shot, then mark the first five minutes better, same, or worse." ;
    recall:deepensStrength recall:HabitStacking ;
    recall:depthScore "0.95"^^xsd:decimal .

recall:StackSecondMicrodose
    a recall:ReminderTemplate ;
    rdfs:label "Kill or keep the ritual" ;
    recall:templateText "Make the warmup earn its place: if the test does not change readiness after three tries, kill it or replace it." ;
    recall:deepensStrength recall:HabitStacking ;
    recall:depthScore "0.88"^^xsd:decimal .

recall:ScoreFirstFiveMinutes
    a recall:ReminderTemplate ;
    rdfs:label "Score the first five" ;
    recall:templateText "Score the first five minutes: legs, breath, and first-step pop; keep only the ritual that changes one." ;
    recall:deepensStrength recall:HabitStacking ;
    recall:depthScore "0.86"^^xsd:decimal .

recall:ChangeAnchorNotAmbition
    a recall:ReminderTemplate ;
    rdfs:label "Change the anchor" ;
    recall:templateText "Change the anchor, not the ambition: test before the first shot, after the first game, or before leaving, then keep the slot that actually fires." ;
    recall:deepensStrength recall:HabitStacking ;
    recall:depthScore "0.84"^^xsd:decimal .

recall:StandingAIDigestGesture
    a recall:ReminderTemplate ;
    rdfs:label "Send the so what" ;
    recall:templateText "Send the so-what before the news: one change, one risk, and one move the person can make this week." ;
    recall:deepensStrength recall:KnowledgeSynthesis ;
    recall:depthScore "0.96"^^xsd:decimal .

recall:TranslateForOneDecision
    a recall:ReminderTemplate ;
    rdfs:label "Make the briefing earn its place" ;
    recall:templateText "Make the briefing earn its place: if it does not change a decision, it was interesting but not useful." ;
    recall:deepensStrength recall:KnowledgeSynthesis ;
    recall:depthScore "0.90"^^xsd:decimal .

recall:NameRecipientDecision
    a recall:ReminderTemplate ;
    rdfs:label "Pick the person before the headline" ;
    recall:templateText "Pick the person before the headline: name the decision they face, then translate only the AI change that alters it." ;
    recall:deepensStrength recall:KnowledgeSynthesis ;
    recall:depthScore "0.88"^^xsd:decimal .

recall:CutInterestingParagraph
    a recall:ReminderTemplate ;
    rdfs:label "Cut the interesting paragraph" ;
    recall:templateText "Cut the interesting paragraph unless it changes a move: send the implication, the risk, and the next action." ;
    recall:deepensStrength recall:KnowledgeSynthesis ;
    recall:depthScore "0.86"^^xsd:decimal .

recall:TwoWeekVerdictLedger
    a recall:ReminderTemplate ;
    rdfs:label "Run the expensive tool audit" ;
    recall:templateText "Run the expensive-tool audit: what did this machine unlock that the old setup actually blocked?" ;
    recall:deepensStrength recall:ToolIntegrationTiming ;
    recall:depthScore "0.94"^^xsd:decimal .

recall:WeekOneAdamPatternCheck
    a recall:ReminderTemplate ;
    rdfs:label "Separate delight from leverage" ;
    recall:templateText "Separate delight from leverage: capture the moment a task became possible, faster, or less emotionally costly." ;
    recall:deepensStrength recall:ToolIntegrationTiming ;
    recall:depthScore "0.90"^^xsd:decimal .

recall:BlockedByOldSetupReceipt
    a recall:ReminderTemplate ;
    rdfs:label "Write the blocked-by-old-setup receipt" ;
    recall:templateText "Write the blocked-by-old-setup receipt: task, old friction, new unlock, and whether it matters again." ;
    recall:deepensStrength recall:ToolIntegrationTiming ;
    recall:depthScore "0.88"^^xsd:decimal .

recall:RefundFantasyHour
    a recall:ReminderTemplate ;
    rdfs:label "Refund the fantasy hour" ;
    recall:templateText "Refund the fantasy hour: if the machine did not save or create one real hour this week, name what still blocks leverage." ;
    recall:deepensStrength recall:ToolIntegrationTiming ;
    recall:depthScore "0.86"^^xsd:decimal .

recall:ScheduleElectrifyingSource
    a recall:ReminderTemplate ;
    rdfs:label "Protect the afterglow" ;
    recall:templateText "Name the source, then protect the hour after it; the afterglow is where the useful output appears." ;
    recall:deepensStrength recall:StrategicLearning ;
    recall:depthScore "0.93"^^xsd:decimal .

recall:MeditateOnVisualPerception
    a recall:ReminderTemplate ;
    rdfs:label "Track spark to output" ;
    recall:templateText "Track the spark-to-output chain: what input made you sharper, and what did it make you build or decide?" ;
    recall:deepensStrength recall:StrategicLearning ;
    recall:depthScore "0.89"^^xsd:decimal .

recall:CaptureTimingFingerprint
    a recall:ReminderTemplate ;
    rdfs:label "Capture the timing fingerprint" ;
    recall:templateText "Capture the timing fingerprint: what time, state, and source made the idea land hard enough to use?" ;
    recall:deepensStrength recall:StrategicLearning ;
    recall:depthScore "0.87"^^xsd:decimal .

recall:TurnSourceIntoAppointment
    a recall:ReminderTemplate ;
    rdfs:label "Turn the source into an appointment" ;
    recall:templateText "Turn the source into an appointment: protect the next window where it can become a draft, decision, or call." ;
    recall:deepensStrength recall:StrategicLearning ;
    recall:depthScore "0.85"^^xsd:decimal .

recall:HabitStackDepthRecommendationRule
    a recall:ReminderRecommendationRule ;
    rdfs:label "Habit stack depth recommendation rule" ;
    recall:triggeredByTemplate recall:HabitStackGymReminder ;
    recall:requiresFeedback recall:PositiveReminderRating ;
    recall:usesFeedbackFrame recall:HabitStackReadinessExperimentFrame ;
    recall:recommendationReason "A positively rated gym habit stack reveals habit stacking; recommend leveling the same stack up toward the ultimate goal rather than broader fitness reminders." ;
    recall:recommendsTemplate
        recall:FoamRollFiveByFive,
        recall:StackSecondMicrodose,
        recall:ScoreFirstFiveMinutes,
        recall:ChangeAnchorNotAmbition .

recall:KnowledgeSynthesisDepthRecommendationRule
    a recall:ReminderRecommendationRule ;
    rdfs:label "Knowledge synthesis depth recommendation rule" ;
    recall:triggeredByTemplate recall:TranslateAIWeekReminder ;
    recall:requiresFeedback recall:PositiveReminderRating ;
    recall:usesFeedbackFrame recall:KnowledgeConsequenceFrame ;
    recall:recommendationReason "A positively rated AI translation reminder reveals knowledge synthesis; recommend grander, more organized gestures of the same service — never smaller steps, which the user dismisses." ;
    recall:recommendsTemplate
        recall:StandingAIDigestGesture,
        recall:TranslateForOneDecision,
        recall:NameRecipientDecision,
        recall:CutInterestingParagraph .

recall:ToolTimingDepthRecommendationRule
    a recall:ReminderRecommendationRule ;
    rdfs:label "Tool timing depth recommendation rule" ;
    recall:triggeredByTemplate recall:CaptureMacBookUnlocksReminder ;
    recall:requiresFeedback recall:PositiveReminderRating ;
    recall:usesFeedbackFrame recall:ToolLeverageVerdictFrame ;
    recall:recommendationReason "A positively rated in-the-moment capture reveals tool integration timing; recommend the verdict checkpoints that read from those captures — capture cadence and verdict cadence are different clocks." ;
    recall:recommendsTemplate
        recall:TwoWeekVerdictLedger,
        recall:WeekOneAdamPatternCheck,
        recall:BlockedByOldSetupReceipt,
        recall:RefundFantasyHour .

recall:StrategicLearningDepthRecommendationRule
    a recall:ReminderRecommendationRule ;
    rdfs:label "Strategic learning depth recommendation rule" ;
    recall:triggeredByTemplate recall:NameMeaningfulSourceReminder ;
    recall:requiresFeedback recall:PositiveReminderRating ;
    recall:usesFeedbackFrame recall:StrategicLearningOutputFrame ;
    recall:recommendationReason "A positively rated source-taste reminder reveals strategic learning; recommend deeper uses of the same taste — the what and when of meaningful information, never the where." ;
    recall:recommendsTemplate
        recall:ScheduleElectrifyingSource,
        recall:MeditateOnVisualPerception,
        recall:CaptureTimingFingerprint,
        recall:TurnSourceIntoAppointment .
