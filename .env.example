# Re_Call environment variables
# Copy to .env locally, and add these to your Claude cloud environment / Vercel.

# Required: OpenAI API key used by the recommender + reminder copy generation.
OPENAI_API_KEY=

# Optional: override default model tiers (defaults shown).
RECALL_OPENAI_TINY_MODEL=gpt-5-nano
RECALL_OPENAI_STANDARD_MODEL=gpt-5-mini
RECALL_OPENAI_REASONING_MODEL=gpt-5
