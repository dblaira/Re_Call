# Re_Call environment variables
# Copy to .env locally, and add these to your cloud/Vercel environment.

# Supabase project wiring.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only Supabase key. Do not expose this in browser/client bundles.
SUPABASE_SERVICE_ROLE_KEY=

# Single-user mode: when requests carry no Bearer JWT, the API acts as this user id
# (and ignores any userId in the request body). Required for the service-role path until
# Supabase Auth login lands; once clients send JWTs, identity comes from the token instead.
SINGLE_USER_ID=

# Required: OpenAI API key used by the recommender + reminder copy generation.
OPENAI_API_KEY=

# Optional: override default model tiers (defaults shown).
RECALL_OPENAI_TINY_MODEL=gpt-5-nano
RECALL_OPENAI_STANDARD_MODEL=gpt-5-mini
RECALL_OPENAI_REASONING_MODEL=gpt-5
