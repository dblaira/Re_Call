PREFIX recall: <https://understood.app/ontology/project-recall#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?ruleName ?sourceTemplate ?revealedStrength ?recommendation ?templateText ?depthScore WHERE {
  ?rule a recall:ReminderRecommendationRule ;
    rdfs:label ?ruleName ;
    recall:triggeredByTemplate recall:ScanCalendarReminder ;
    recall:requiresFeedback recall:PositiveReminderRating ;
    recall:recommendsTemplate ?candidate .

  recall:ScanCalendarReminder rdfs:label ?sourceTemplate ;
    recall:revealsStrength ?strength .

  ?strength rdfs:label ?revealedStrength .
  ?candidate rdfs:label ?recommendation ;
    recall:templateText ?templateText ;
    recall:depthScore ?depthScore .
}
ORDER BY DESC(?depthScore)
